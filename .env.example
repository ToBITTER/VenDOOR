# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database
DATABASE_ECHO=False

# Redis
REDIS_URL=redis://localhost:6379

# Korapay API
KORAPAY_PUBLIC_KEY=pk_live_xxx
KORAPAY_SECRET_KEY=sk_live_xxx
KORAPAY_WEBHOOK_SECRET=whsec_xxx
KORAPAY_ENCRYPTION_KEY=your_32_char_encryption_key
KORAPAY_BASE_URL=https://api.korapay.com/merchant/api/v1
KORAPAY_PAYMENT_CHANNELS=card,bank_transfer,pay_with_bank

# Celery
CELERY_BROKER_URL=redis://localhost:6379
CELERY_RESULT_BACKEND=redis://localhost:6379

# App
DEBUG=False
ALLOWED_HOSTS=your-api-domain.onrender.com
API_HOST=https://your-api-domain.onrender.com
BOT_WEBHOOK_URL=https://your-api-domain.onrender.com/webhooks/telegram
ESCROW_RELEASE_HOURS=48
DELIVERY_AGENT_SELF_SIGNUP_AUTO_ACTIVATE=False

# Admin
ADMIN_TELEGRAM_ID=123456789
ADMIN_API_KEY=your_admin_api_key
