# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vendoor
DATABASE_ECHO=False

# Redis
REDIS_URL=redis://localhost:6379/0

# Korapay API
KORAPAY_PUBLIC_KEY=your_korapay_public_key
KORAPAY_SECRET_KEY=your_korapay_secret_key
KORAPAY_BASE_URL=https://api.korapay.com/merchant/api/v1

# Celery & RabbitMQ/Redis
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# App Settings
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
API_HOST=http://localhost:8000
BOT_WEBHOOK_URL=https://yourdomain.com/webhooks/telegram
TELEGRAM_WEBHOOK_SECRET=use_a_long_random_secret
ESCROW_RELEASE_HOURS=48

# Admin Settings
ADMIN_TELEGRAM_ID=your_admin_telegram_id
ADMIN_API_KEY=your_admin_api_key

# Korapay webhook signature (optional but recommended)
KORAPAY_WEBHOOK_SECRET=your_korapay_webhook_secret
